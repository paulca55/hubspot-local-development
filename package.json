{
  "name": "hubspot-local-development",
  "version": "1.0.0",
  "browserslist": [
    ">0.25%"
  ],
  "config": {
    "portalFolder": "website",
    "sassLoadPaths": "--load-path=src/scss --load-path=src/scss/abstracts"
  },
  "scripts": {
    "images": "imagemin ./src/images/* --out-dir=./dist/images",
    "scss:global": "sass $npm_package_config_sassLoadPaths --style compressed --no-source-map src/scss:dist/css",
    "scss:modules": "sass $npm_package_config_sassLoadPaths --style compressed --no-source-map src/modules:dist/modules",
    "autoprefixer:global": "postcss --use autoprefixer --no-map --replace ./dist/css/**/*.css ",
    "autoprefixer:modules": "postcss --use autoprefixer --no-map --replace ./dist/modules/**/*.css ",
    "css:global": "run-s scss:global autoprefixer:global",
    "css:modules": "run-s scss:modules autoprefixer:modules",
    "scripts:global": "parcel build ./src/js/scripts.js --no-source-maps --out-dir ./dist/js",
    "scripts:modules": "npx babel ./src/modules/ --extensions='.js' --out-dir ./dist/modules/",
    "html:templates": "html-minifier --collapse-whitespace --minify-js --minify-css --input-dir src/templates --output-dir dist/templates --file-ext html",
    "html:modules": "html-minifier --collapse-whitespace --minify-js --minify-css --input-dir src/modules --output-dir dist/modules --file-ext html",
    "copy-module-files": "copyfiles --up 1 './src/modules/**' --exclude './src/modules/**/module.*' './dist/'",
    "watch:scss-global": "onchange './src/scss/**/*.scss' -- run-s css:global",
    "watch:scss-modules": "onchange './src/modules/**/*.scss' -- run-s css:modules",
    "watch:js-global": "onchange './src/js/**/*.js' -- run-s scripts:global",
    "watch:js-modules": "onchange './src/modules/**/module.js' -- run-s scripts:modules",
    "watch:html-templates": "onchange './src/templates/**/*.html' -- run-s html:templates",
    "watch:html-modules": "onchange './src/modules/**/*.html' -- run-s html:modules",
    "watch:module-files": "onchange './src/modules/**/*.json' -- run-s copy-module-files",
    "watch:images": "onchange './src/images' -- run-s images",
    "hs-watch": "npx hs watch ./dist $npm_package_config_portalFolder",
    "build": "run-s scss:* scripts:* html:* copy-module-files images",
    "start": "run-p hs-watch watch:*"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.5",
    "copyfiles": "^2.4.1",
    "html-minifier": "^4.0.0",
    "@babel/core": "^7.12.3",
    "@hubspot/cms-cli": "^2.2.2",
    "autoprefixer": "^9.8.6",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-prettier": "^3.1.4",
    "imagemin-cli": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^6.1.1",
    "parcel-bundler": "^1.12.4",
    "postcss-cli": "^6.1.3",
    "prettier": "^1.19.1",
    "sass": "^1.35.2",
    "stylelint": "^12.0.1",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-prettier": "^1.1.2"
  }
}
